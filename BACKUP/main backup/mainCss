/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AI SIZE FIX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.ai-panel{

    width:min(92%,720px);

    height:min(82vh,760px);

}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CONVERSATION LAYOUT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.ai-conversation{

    display:flex;

    flex-direction:column;

    gap:16px;

    padding:
        22px
        22px
        18px;

    overflow-y:auto;

}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
INTRO MESSAGE FIX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.ai-intro-message{

    max-width:100%;

    align-self:stretch;

}

.ai-intro-message .ai-bubble{

    width:100%;

    padding:
        24px
        26px;

    border-radius:30px;

}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NORMAL MESSAGE FIX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.ai-message{

    display:flex;

    align-items:flex-end;

    gap:12px;

    max-width:78%;

    padding:0;

}

.ai-bubble{

    padding:
        16px
        18px;

    border-radius:24px;

    line-height:1.75;

}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
INPUT AREA FIX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.ai-input-shell{

    padding:
        0
        22px
        22px;

    border-top:
        1px solid rgba(255,255,255,.05);

}

.ai-input-wrap{

    display:flex;

    align-items:center;

    gap:12px;

    margin-top:18px;

}

.ai-input{

    min-height:56px;

    padding:
        18px
        22px;

    border-radius:20px;

}

.ai-send-btn{

    min-width:120px;

    height:56px;

    border-radius:18px;

    flex-shrink:0;

}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CHIPS FIX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

.ai-suggestions{

    padding:
        4px
        22px
        18px;

    gap:10px;

}

.suggestion-chip{

    padding:
        10px
        16px;

    font-size:.84rem;

}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MOBILE FIX
━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

@media(max-width:768px){

    .ai-panel{

        width:94%;

        height:88vh;

    }

    .ai-message{

        max-width:92%;

    }

    .ai-input-wrap{

        flex-direction:column;

        align-items:stretch;

    }

    .ai-send-btn{

        width:100%;

    }

}